{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClaimSchema",
  "description": "Schema for claim definitions in the research ledger.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the claim."
    },
    "claim": {
      "type": "string",
      "description": "The assertion statement."
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of source IDs backing this claim."
    },
    "status": {
      "type": "string",
      "enum": ["evidence_needed", "verified", "placeholder"],
      "description": "The verification status of the claim."
    },
    "notes": {
      "type": "string",
      "description": "Optional notes or details."
    }
  },
  "required": ["id", "claim", "source_ids", "status"],
  "additionalProperties": false
}
